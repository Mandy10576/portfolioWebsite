# AWS RDS PostgreSQL connection string format
# Replace with your AWS RDS Endpoint, DB user, DB password, and DB name
DATABASE_URL="postgresql://<db_username>:<db_password>@<rds-instance-endpoint>.rds.amazonaws.com:5432/<db_name>?sslmode=require"

# JWT Secret Key for Admin Sessions (Set a random strong string in Vercel environment variables)
JWT_SECRET="your-secure-random-jwt-secret-key"

# Default Admin login setup
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="YourSecurePassword123"
